<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.profile.ProfileStep2Activity">

    <!-- ═══════════════════════════════════ -->
    <!--  TOP BAR                            -->
    <!-- ═══════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:contentDescription="@string/cd_back_button"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <FrameLayout
        android:id="@+id/profileFrame"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack">

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_profile_circle" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_profile_icon"
            android:src="@drawable/ic_profile_avatar" />

    </FrameLayout>

    <!-- ═══════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                 -->
    <!-- ═══════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- ═══════════════════════════════════ -->
            <!--  STEP INDICATOR + PROGRESS          -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvStepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="STEP 2 OF 4"
                android:textColor="@color/step_indicator_red"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvStepTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="@string/step_2_title"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/step_2_percent"
                    android:textColor="@color/text_caption"
                    android:textSize="12sp" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track" />

                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_fill" />

            </FrameLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  ACTIVITY LEVEL SECTION             -->
            <!-- ═══════════════════════════════════ -->

            <!-- Section header with icon -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_section_icon_circle" />

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_running" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="serif"
                    android:text="@string/activity_level_title"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/activity_level_subtitle"
                android:textColor="@color/text_caption"
                android:textSize="14sp" />

            <!-- Activity Card: Sedentary -->
            <LinearLayout
                android:id="@+id/cardSedentary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_activity_card_selected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sedentary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_sedentary"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/activity_sedentary_desc"
                        android:textColor="@color/text_caption"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Activity Card: Moderate -->
            <LinearLayout
                android:id="@+id/cardModerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_activity_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_moderate" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_moderate"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/activity_moderate_desc"
                        android:textColor="@color/text_caption"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Activity Card: Very Active -->
            <LinearLayout
                android:id="@+id/cardVeryActive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_activity_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_very_active" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_very_active"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/activity_very_active_desc"
                        android:textColor="@color/text_caption"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  SLEEP QUALITY SECTION              -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/sleepCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_sleep_card"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Sleep header with icon -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp">

                        <View
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_emoji_circle" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_sleep_moon" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="serif"
                        android:text="@string/sleep_quality_title"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Average Hours row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.06"
                        android:text="@string/sleep_avg_hours"
                        android:textColor="@color/text_caption"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSleepHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:textColor="@color/primary_green"
                        android:textSize="28sp"
                        android:textStyle="bold|italic"
                        tools:text="7.5 hrs" />

                </LinearLayout>

                <!-- Sleep Slider -->
                <SeekBar
                    android:id="@+id/seekSleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="120"
                    android:progress="70"
                    android:splitTrack="false"
                    android:progressDrawable="@drawable/bg_sleep_slider_track"
                    android:thumb="@drawable/bg_slider_thumb" />

                <!-- Slider labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sleep_less_than_4"
                        android:textColor="@color/text_subtext_grey"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/sleep_optimal"
                        android:textColor="@color/text_subtext_grey"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/sleep_more_than_10"
                        android:textColor="@color/text_subtext_grey"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Sleep Quality label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="0.06"
                    android:text="@string/sleep_quality_label"
                    android:textColor="@color/text_caption"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Sleep Quality emojis -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:weightSum="3"
                    android:orientation="horizontal">

                    <!-- Restless -->
                    <LinearLayout
                        android:id="@+id/btnRestless"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/emojiRestless"
                            android:layout_width="44dp"
                            android:layout_height="44dp">

                            <View
                                android:id="@+id/emojiRestlessBg"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_emoji_circle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="😟"
                                android:textSize="20sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/sleep_restless"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Average -->
                    <LinearLayout
                        android:id="@+id/btnAverage"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/emojiAverage"
                            android:layout_width="44dp"
                            android:layout_height="44dp">

                            <View
                                android:id="@+id/emojiAverageBg"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_emoji_circle_selected" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="😐"
                                android:textSize="20sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/sleep_average"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Deep -->
                    <LinearLayout
                        android:id="@+id/btnDeep"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/emojiDeep"
                            android:layout_width="44dp"
                            android:layout_height="44dp">

                            <View
                                android:id="@+id/emojiDeepBg"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_emoji_circle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="😴"
                                android:textSize="20sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/sleep_deep"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  INFO CARD — "Did you know?"        -->
            <!-- ═══════════════════════════════════ -->

            <FrameLayout
                android:id="@+id/infoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_info_card"
                android:clipChildren="false"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Plant Image -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:layout_gravity="center_vertical"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_herbs_bowl" />

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="@string/info_did_you_know"
                            android:textColor="@color/step_indicator_red"
                            android:textSize="16sp"
                            android:textStyle="bold|italic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingMultiplier="1.4"
                            android:text="@string/info_sleep_ayurveda"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  CTA BUTTON                         -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="@dimen/onboarding_btn_height"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_primary"
                android:clickable="true"
                android:elevation="3dp"
                android:focusable="true"
                android:gravity="center"
                android:letterSpacing="0.02"
                android:text="@string/btn_continue_nutrition"
                android:textColor="@color/white"
                android:textSize="@dimen/onboarding_btn_text_size"
                android:textStyle="bold" />

            <!-- Save for Later -->
            <TextView
                android:id="@+id/btnSaveForLater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.1"
                android:paddingVertical="8dp"
                android:text="@string/btn_save_for_later"
                android:textColor="@color/text_caption"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
