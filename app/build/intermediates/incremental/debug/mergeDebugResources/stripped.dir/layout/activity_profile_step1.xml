<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.profile.ProfileStep1Activity">

    <!-- ═══════════════════════════════════ -->
    <!--  TOP BAR                            -->
    <!-- ═══════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:contentDescription="@string/cd_back_button"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <!-- Profile icon with circle background -->
    <FrameLayout
        android:id="@+id/profileFrame"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack">

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_profile_circle" />

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_profile_icon"
            android:src="@drawable/ic_profile_avatar" />

    </FrameLayout>

    <!-- ═══════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                 -->
    <!-- ═══════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Botanical corner decoration (top-right) -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="end"
                android:layout_marginTop="-8dp"
                android:alpha="0.35"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_botanical_corner" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <!-- ═══════════════════════════════════ -->
                <!--  STEP INDICATOR + PROGRESS          -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:id="@+id/tvStepIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:textColor="@color/step_indicator_red"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="STEP 01 OF 04" />

                <!-- Title + Percent Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvStepTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:text="@string/step_1_title"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_caption"
                        android:textSize="12sp"
                        tools:text="25% Complete" />

                </LinearLayout>

                <!-- Progress Bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_track" />

                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_fill" />

                </FrameLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  DESCRIPTION                        -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:lineSpacingMultiplier="1.55"
                    android:textColor="@color/text_body"
                    android:textSize="15sp"
                    tools:text="To begin your Ayurvedic journey, we need to understand your unique physical vessel. These metrics help us calculate your baseline Prakriti." />

                <!-- ═══════════════════════════════════ -->
                <!--  AGE FIELD                          -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/label_age"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_input"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_age"
                        android:inputType="number"
                        android:maxLength="3"
                        android:maxLines="1"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/text_heading_dark"
                        android:textColorHint="@color/text_subtext_grey"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="20dp"
                        android:text="@string/suffix_years"
                        android:textColor="@color/text_subtext_grey"
                        android:textSize="14sp" />

                </FrameLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  GENDER SELECTION                   -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/label_gender"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/genderRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnFemale"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gender_selected"
                        android:gravity="center"
                        android:text="@string/gender_female"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnMale"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gender_unselected"
                        android:gravity="center"
                        android:text="@string/gender_male"
                        android:textColor="@color/text_body"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnOther"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gender_unselected"
                        android:gravity="center"
                        android:text="@string/gender_other"
                        android:textColor="@color/text_body"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  HEIGHT FIELD                       -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/label_height"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etHeight"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_input"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_height"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        android:maxLines="1"
                        android:paddingStart="20dp"
                        android:paddingEnd="100dp"
                        android:textColor="@color/text_heading_dark"
                        android:textColorHint="@color/text_subtext_grey"
                        android:textSize="16sp" />

                    <!-- CM / FT toggle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_unit_toggle_group"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/btnCm"
                            android:layout_width="38dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_unit_selected"
                            android:gravity="center"
                            android:text="@string/unit_cm"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnFt"
                            android:layout_width="38dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_unit_unselected"
                            android:gravity="center"
                            android:text="@string/unit_ft"
                            android:textColor="@color/text_body"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  WEIGHT FIELD                       -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/label_weight"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_input"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_weight"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        android:maxLines="1"
                        android:paddingStart="20dp"
                        android:paddingEnd="100dp"
                        android:textColor="@color/text_heading_dark"
                        android:textColorHint="@color/text_subtext_grey"
                        android:textSize="16sp" />

                    <!-- KG / LB toggle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_unit_toggle_group"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/btnKg"
                            android:layout_width="38dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_unit_selected"
                            android:gravity="center"
                            android:text="@string/unit_kg"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnLb"
                            android:layout_width="38dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_unit_unselected"
                            android:gravity="center"
                            android:text="@string/unit_lb"
                            android:textColor="@color/text_body"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  INFO CARD — "Why this matters?"    -->
                <!-- ═══════════════════════════════════ -->

                <FrameLayout
                    android:id="@+id/infoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_info_card"
                    android:clipChildren="false"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Text content -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="@string/info_title"
                                android:textColor="@color/text_heading_dark"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingMultiplier="1.45"
                                android:text="@string/info_description"
                                android:textColor="@color/text_caption"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <!-- Leaf illustration -->
                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="top"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_leaf_info" />

                    </LinearLayout>

                </FrameLayout>

                <!-- ═══════════════════════════════════ -->
                <!--  CONTINUE BUTTON                    -->
                <!-- ═══════════════════════════════════ -->

                <TextView
                    android:id="@+id/btnContinue"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:letterSpacing="0.02"
                    android:text="@string/btn_continue_lifestyle"
                    android:textColor="@color/white"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold" />

                <!-- Footer -->
                <TextView
                    android:id="@+id/tvFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/profile_footer"
                    android:textColor="@color/text_subtext_grey"
                    android:textSize="11sp" />

            </LinearLayout>

        </FrameLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
