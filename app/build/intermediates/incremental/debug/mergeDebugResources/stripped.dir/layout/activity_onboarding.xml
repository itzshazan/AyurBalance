<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/onboardingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.onboarding.OnboardingActivity">

    <!-- ═══════════════════════════════════════ -->
    <!--  HERO IMAGE SECTION (top ~50%)          -->
    <!-- ═══════════════════════════════════════ -->

    <ImageView
        android:id="@+id/heroImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/cd_hero_image"
        android:scaleType="centerCrop"
        android:src="@drawable/onboarding_hero_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.50"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Dark gradient overlay at top for branding text readability -->
    <View
        android:id="@+id/gradientTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/gradient_hero_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.22"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Fade-to-beige gradient at bottom of hero for smooth transition -->
    <View
        android:id="@+id/gradientBottom"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/gradient_hero_bottom"
        app:layout_constraintBottom_toBottomOf="@id/heroImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- "AyurBalance" branding over hero — serif italic, sage-green -->
    <TextView
        android:id="@+id/tvBrandName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="20dp"
        android:alpha="0.85"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/hero_brand_text"
        android:textSize="@dimen/onboarding_brand_size"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ═══════════════════════════════════════ -->
    <!--  BOTTOM CONTENT CONTAINER               -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Guideline for bottom container top edge -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.44" />

    <!-- Bottom sheet background with rounded top corners -->
    <View
        android:id="@+id/bottomContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_onboarding_bottom"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideContent" />

    <!-- ═══════════════════════════════════════ -->
    <!--  FLOATING CARD (overlaps boundary)      -->
    <!-- ═══════════════════════════════════════ -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/floatingCard"
        android:layout_width="105dp"
        android:layout_height="115dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#E8FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.36">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/cd_plant_icon"
                android:src="@drawable/ic_plant_pot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="@string/floating_card_natural"
                android:textColor="@color/text_tagline_brown"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="@string/floating_card_balance"
                android:textColor="@color/text_tagline_brown"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════ -->
    <!--  CONTENT INSIDE BOTTOM CONTAINER        -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Page indicator dots -->
    <LinearLayout
        android:id="@+id/dotIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="28dp"
        android:elevation="3dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideContent">

        <!-- Dot 1 — active (elongated pill) -->
        <View
            android:id="@+id/dot1"
            android:layout_width="@dimen/onboarding_dot_active_width"
            android:layout_height="@dimen/onboarding_dot_height"
            android:background="@drawable/bg_dot_active" />

        <!-- Dot 2 — inactive -->
        <View
            android:id="@+id/dot2"
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 3 — inactive -->
        <View
            android:id="@+id/dot3"
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

    </LinearLayout>

    <!-- Heading line 1: "Your Personal" — serif bold, dark -->
    <TextView
        android:id="@+id/tvHeadingLine1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="22dp"
        android:elevation="3dp"
        android:fontFamily="serif"
        android:text="@string/onboarding1_heading_1"
        android:textColor="@color/text_heading_dark"
        android:textSize="@dimen/onboarding_heading_size"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dotIndicators" />

    <!-- Heading line 2: "Dosha Guide." — serif bold italic, green -->
    <TextView
        android:id="@+id/tvHeadingLine2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="2dp"
        android:elevation="3dp"
        android:fontFamily="serif"
        android:text="@string/onboarding1_heading_2"
        android:textColor="@color/text_dark_green"
        android:textSize="@dimen/onboarding_heading_size"
        android:textStyle="bold|italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeadingLine1" />

    <!-- Description with "(Prakriti)" highlighted -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:elevation="3dp"
        android:lineSpacingExtra="4dp"
        android:text="@string/onboarding1_description"
        android:textColor="@color/text_tagline_brown"
        android:textSize="@dimen/onboarding_desc_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeadingLine2" />

    <!-- ═══════════════════════════════════════ -->
    <!--  ACTION BUTTONS                         -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Primary: "Next →" — filled dark green pill -->
    <TextView
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_btn_primary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_next"
        android:textColor="@color/white"
        android:textSize="@dimen/onboarding_btn_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnSkip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Secondary: "Skip" — outlined ghost pill -->
    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_btn_secondary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_skip"
        android:textColor="@color/text_body"
        android:textSize="@dimen/onboarding_btn_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
