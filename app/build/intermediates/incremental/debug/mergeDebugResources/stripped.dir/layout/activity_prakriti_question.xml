<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/prakritiRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.prakriti.PrakritiQuestionActivity">

    <!-- ═══════════════════════════════════ -->
    <!--  TOP BAR                            -->
    <!-- ═══════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:contentDescription="@string/cd_back_button"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/prakriti_assessment_title"
        android:textColor="@color/text_heading_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <TextView
        android:id="@+id/btnSaveExit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:letterSpacing="0.05"
        android:padding="4dp"
        android:text="Save &amp; Exit"
        android:textColor="@color/primary_green"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <!-- ═══════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                 -->
    <!-- ═══════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- ═══════════════════════════════════ -->
            <!--  QUESTION CONTENT (fades on change) -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/questionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Dimension label -->
                <TextView
                    android:id="@+id/tvDimensionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="PHYSICAL CONSTITUTION"
                    android:textColor="@color/step_indicator_red"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="PHYSICAL CONSTITUTION" />

                <!-- Question progress row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvQuestionProgress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:text="Question 1 of 42"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Question 1 of 42" />

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2%"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="2%" />

                </LinearLayout>

                <!-- Progress bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="8dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_track" />

                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_fill" />

                </FrameLayout>

                <!-- Question text -->
                <TextView
                    android:id="@+id/tvQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:lineSpacingMultiplier="1.2"
                    android:text="How would you describe your body frame?"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="How would you describe your body frame?" />

                <!-- ═══════════════════════════════════ -->
                <!--  OPTION CARDS                       -->
                <!-- ═══════════════════════════════════ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <!-- VATA option card -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardVata"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_activity_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/tvVataLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.12"
                            android:text="@string/prakriti_vata"
                            android:textColor="@color/vata_purple"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/radioVata"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_radio_unselected"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvVataOption"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="28dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Thin, lean, or lanky — difficult to gain weight"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvVataLabel"
                            tools:text="Thin, lean, or lanky — difficult to gain weight" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- PITTA option card -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardPitta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_activity_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/tvPittaLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.12"
                            android:text="@string/prakriti_pitta"
                            android:textColor="@color/pitta_terracotta"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/radioPitta"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_radio_unselected"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvPittaOption"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="28dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Medium, athletic, and well-proportioned"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvPittaLabel"
                            tools:text="Medium, athletic, and well-proportioned" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- KAPHA option card -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardKapha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_activity_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/tvKaphaLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.12"
                            android:text="@string/prakriti_kapha"
                            android:textColor="@color/primary_green"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/radioKapha"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_radio_unselected"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvKaphaOption"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="28dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Broad, stocky, or large — tends to gain weight easily"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvKaphaLabel"
                            tools:text="Broad, stocky, or large — tends to gain weight easily" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </LinearLayout>
            <!-- END questionContent -->

            <!-- ═══════════════════════════════════ -->
            <!--  LIVE PROFILE ANALYSIS              -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/liveAnalysisCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_live_analysis_card"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/dot_green_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="@string/label_live_profile_analysis"
                        android:textColor="@color/primary_green"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Vata bar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="Vata"
                        android:textColor="@color/text_body"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVataPercent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:text="33%"
                        android:textColor="@color/vata_purple"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="15%" />

                    <FrameLayout
                        android:id="@+id/barVataTrack"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_progress_track" />

                        <View
                            android:id="@+id/barVata"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_dosha_bar_vata" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Pitta bar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="Pitta"
                        android:textColor="@color/text_body"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPittaPercent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:text="34%"
                        android:textColor="@color/pitta_terracotta"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="45%" />

                    <FrameLayout
                        android:id="@+id/barPittaTrack"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_progress_track" />

                        <View
                            android:id="@+id/barPitta"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_dosha_bar_pitta" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Kapha bar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="Kapha"
                        android:textColor="@color/text_body"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvKaphaPercent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:text="33%"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="40%" />

                    <FrameLayout
                        android:id="@+id/barKaphaTrack"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_progress_track" />

                        <View
                            android:id="@+id/barKapha"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_dosha_bar_kapha" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Constitution note -->
                <TextView
                    android:id="@+id/tvConstitutionNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-light"
                    android:text="@string/prakriti_note_default"
                    android:textColor="@color/text_caption"
                    android:textSize="10sp"
                    android:textStyle="italic" />

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  NAVIGATION BUTTONS ROW             -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_ghost"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="← Back"
                    android:textColor="@color/primary_green"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:layout_weight="2"
                    android:alpha="0.45"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/btn_next_question"
                    android:textColor="@color/white"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
