<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reminderRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_cream">

    <!-- ══════════════════════════════════ -->
    <!--  HEADER                            -->
    <!-- ══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/reminderHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_result_header"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Back + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back_arrow"
                android:scaleType="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_badge"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTIFICATIONS"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reminders"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

            </LinearLayout>

        </LinearLayout>

        <!-- Subtitle: day + season -->
        <TextView
            android:id="@+id/tvReminderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thursday · Vasanta"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.04" />

    </LinearLayout>

    <!-- ══════════════════════════════════ -->
    <!--  SCROLLABLE REMINDER FEED          -->
    <!-- ══════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- ══════════════════════════════════ -->
    <!--  BOTTOM NAVIGATION                 -->
    <!-- ══════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_cream"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_home"
        app:elevation="8dp" />

</LinearLayout>
