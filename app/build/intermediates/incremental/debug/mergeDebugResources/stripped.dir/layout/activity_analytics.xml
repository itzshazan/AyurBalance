<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/analyticsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream">

    <!-- Scrollable content sits above bottom nav -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <FrameLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_green"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="60dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="80dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAST 7 DAYS"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analytics"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="4dp"
                    android:src="@drawable/ic_vegan_leaf"
                    android:alpha="0.20"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null" />

            </FrameLayout>

            <!-- ── Summary Cards Row ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:weightSum="2">

                <!-- AVG DAILY KCAL -->
                <LinearLayout
                    android:id="@+id/cardAvgKcal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_analytics_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG DAILY KCAL"
                        android:textColor="@color/text_caption"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvAvgKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvKcalDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/primary_green"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

                <!-- DOSHA ALIGNMENT -->
                <LinearLayout
                    android:id="@+id/cardDoshaAlignment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_analytics_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOSHA ALIGNMENT"
                        android:textColor="@color/text_caption"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvDoshaAlignment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvAlignmentDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/primary_green"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Chart Card ──────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/chartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_analytics_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosha Alignment Trend"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7-day alignment score"
                    android:textColor="@color/text_caption"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp" />

                <com.ayurbalance.ui.analytics.AnalyticsChartView
                    android:id="@+id/chartView"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <!-- ── Macro Card ──────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/macroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_analytics_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly Macro Average"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMacros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

            <!-- ── Insight Card ────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/insightCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_insight_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿  Ayurvedic Insight"
                    android:textColor="@color/primary_green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_body"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- ── Empty State ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="56dp"
                android:paddingBottom="56dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_vegan_leaf"
                    android:alpha="0.35"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start logging meals to unlock\nyour wellness insights"
                    android:textColor="@color/text_caption"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom Navigation ───────────────────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_home"
        app:labelVisibilityMode="labeled"
        app:itemTextColor="@color/text_caption" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
