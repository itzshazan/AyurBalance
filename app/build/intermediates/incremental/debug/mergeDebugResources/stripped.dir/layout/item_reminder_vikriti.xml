<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_info_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:padding="18dp"
    android:elevation="2dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_check_circle"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY CHECK-IN"
                android:textColor="@color/text_caption"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:00 PM"
                android:textColor="@color/text_caption"
                android:textSize="10sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvVikritiStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tag_neutral"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Pending"
            android:textColor="@color/text_body"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How was your day?"
        android:textColor="@color/text_heading_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Log your Vikriti · 2 min"
        android:textColor="@color/text_body"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnStartCheckin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_calm_button"
        android:gravity="center"
        android:text="Start check-in  →"
        android:textColor="@color/pitta_terracotta"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
