<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_alert_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:padding="18dp"
    android:gravity="center_vertical"
    android:elevation="1dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_leaf_sprout"
        android:scaleType="fitCenter"
        android:layout_marginEnd="14dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvInsightRitu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEASONAL WISDOM"
            android:textColor="@color/text_caption"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvInsightText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consistency is care. Small mindful actions today, better balance tomorrow."
            android:textColor="@color/text_body"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

</LinearLayout>
