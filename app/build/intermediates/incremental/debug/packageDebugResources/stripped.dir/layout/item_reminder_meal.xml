<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_meal_plan_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:padding="18dp"
    android:elevation="2dp">

    <!-- Type label + time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvMealTypeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MEAL TIMING"
            android:textColor="@color/text_caption"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.10" />

        <TextView
            android:id="@+id/tvMealTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1:00 PM"
            android:textColor="@color/text_caption"
            android:textSize="11sp"
            android:letterSpacing="0.06" />

    </LinearLayout>

    <!-- Meal name -->
    <TextView
        android:id="@+id/tvMealName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Moong dal khichdi"
        android:textColor="@color/text_heading_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginBottom="4dp" />

    <!-- Dosha + kcal -->
    <TextView
        android:id="@+id/tvMealMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pitta-pacifying · 320 kcal"
        android:textColor="@color/text_body"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnViewMeal"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_primary"
            android:gravity="center"
            android:text="View meal"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSnooze"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_ghost"
            android:gravity="center"
            android:text="Snooze 15m"
            android:textColor="@color/text_body"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
