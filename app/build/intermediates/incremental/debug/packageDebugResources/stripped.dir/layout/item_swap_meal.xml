<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_meal_plan_card"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSwapMealName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vegetable Millet Bowl"
            android:textColor="@color/text_heading_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/tvSwapMealMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="290 kcal · 25 min"
            android:textColor="@color/text_caption"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvSwapSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btn_primary"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="Select"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
