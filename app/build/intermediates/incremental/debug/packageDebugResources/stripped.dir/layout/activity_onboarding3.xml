<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/onboarding3Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.onboarding.Onboarding3Activity">

    <!-- ═══════════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                     -->
    <!-- ═══════════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnComplete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- ─── STEP PILL ─── -->
            <TextView
                android:id="@+id/tvStepPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_vision_pill"
                android:letterSpacing="0.12"
                android:paddingHorizontal="16dp"
                android:paddingVertical="7dp"
                android:text="@string/step_3_of_3"
                android:textColor="@color/primary_green"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- ─── HEADING ─── -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/onboarding3_heading"
                android:textColor="@color/text_heading_dark"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- ─── DESCRIPTION ─── -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.35"
                android:text="@string/onboarding3_description"
                android:textColor="@color/text_caption"
                android:textSize="14sp" />

            <!-- ═══════════════════════════════════ -->
            <!--  CURRENT STATE CARD                 -->
            <!-- ═══════════════════════════════════ -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrentState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/surface_cream"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="18dp"
                    android:paddingBottom="14dp"
                    android:paddingHorizontal="18dp">

                    <!-- CURRENT STATE label -->
                    <TextView
                        android:id="@+id/tvCurrentStateLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="@string/current_state_label"
                        android:textColor="@color/text_caption"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Optimal Balance title -->
                    <TextView
                        android:id="@+id/tvOptimalBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="@string/optimal_balance"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="20sp"
                        android:textStyle="bold|italic"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvCurrentStateLabel" />

                    <!-- ACTIVE badge -->
                    <TextView
                        android:id="@+id/tvActiveBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_active_badge"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="@string/active_label"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvOptimalBalance" />

                    <!-- Leaf circle icon (top-right) -->
                    <ImageView
                        android:id="@+id/icLeafCircle"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:contentDescription="@string/cd_leaf_icon_card"
                        android:src="@drawable/ic_leaf_circle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Dosha Visualization Bars -->
                    <LinearLayout
                        android:id="@+id/doshaVisualization"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvActiveBadge">

                        <!-- PIT (short salmon mound — text inside) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDoshaPit"
                                android:layout_width="55dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_dosha_pit"
                                android:transformPivotY="48dp"
                                android:gravity="center_horizontal|bottom"
                                android:paddingBottom="6dp"
                                android:letterSpacing="0.08"
                                android:text="@string/dosha_pit_label"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- VATA (tall green mound — tallest, text inside) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDoshaVata"
                                android:layout_width="60dp"
                                android:layout_height="78dp"
                                android:background="@drawable/bg_dosha_vata"
                                android:transformPivotY="78dp"
                                android:gravity="center_horizontal|bottom"
                                android:paddingBottom="6dp"
                                android:letterSpacing="0.08"
                                android:text="@string/dosha_vata_label"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- KAP (medium peach mound — text inside) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDoshaKap"
                                android:layout_width="55dp"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_dosha_kap"
                                android:transformPivotY="52dp"
                                android:gravity="center_horizontal|bottom"
                                android:paddingBottom="6dp"
                                android:letterSpacing="0.08"
                                android:text="@string/dosha_kap_label"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════ -->
            <!--  METRICS ROW (Energy + Digestion)   -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/metricsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- ─── ENERGY CARD ─── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEnergy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/surface_cream"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Icon + label row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="@string/cd_energy_icon"
                                android:src="@drawable/ic_lightning" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:letterSpacing="0.08"
                                android:text="@string/energy_label"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Value -->
                        <TextView
                            android:id="@+id/tvEnergyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/energy_value"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <!-- Progress bar -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="10dp">

                            <!-- Track -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/progress_track_light" />

                            <!-- Fill (60%) -->
                            <View
                                android:id="@+id/progressEnergyFill"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/energy_orange"
                                android:scaleX="0.60"
                                android:transformPivotX="0px" />

                        </FrameLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ─── DIGESTION CARD ─── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDigestion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/surface_cream"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Icon + label row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="@string/cd_digestion_icon"
                                android:src="@drawable/ic_leaf_small_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:letterSpacing="0.08"
                                android:text="@string/digestion_label"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Value row: 8.4 /10 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:baselineAligned="true"
                            android:gravity="bottom"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvDigestionValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/digestion_value"
                                android:textColor="@color/text_heading_dark"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/digestion_unit"
                                android:textColor="@color/text_caption"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <!-- Progress bar -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="10dp">

                            <!-- Track -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/progress_track_light" />

                            <!-- Fill (84%) -->
                            <View
                                android:id="@+id/progressDigestionFill"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/primary_green"
                                android:scaleX="0.84"
                                android:transformPivotX="0px" />

                        </FrameLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  VITALITY TRENDS GRAPH CARD         -->
            <!-- ═══════════════════════════════════ -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGraph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface_cream"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- VITALITY TRENDS label -->
                    <TextView
                        android:id="@+id/tvVitalityLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.06"
                        android:text="@string/vitality_trends_label"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Week 12 badge -->
                    <TextView
                        android:id="@+id/tvWeekBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_week_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="@string/week_12_label"
                        android:textColor="@color/primary_green"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Graph line -->
                    <ImageView
                        android:id="@+id/ivGraph"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        android:contentDescription="@string/cd_vitality_graph"
                        android:scaleType="fitXY"
                        android:src="@drawable/graph_vitality_animated"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvVitalityLabel" />

                    <!-- Day labels row -->
                    <LinearLayout
                        android:id="@+id/dayLabels"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivGraph">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_mon"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_tue"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_wed"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_thu"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_fri"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_sat"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/day_sun"
                            android:textColor="@color/text_caption"
                            android:textSize="9sp" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════ -->
    <!--  FIXED BOTTOM SECTION                   -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Primary: "Complete Setup →" -->
    <TextView
        android:id="@+id/btnComplete"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_btn_primary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_complete_setup"
        android:textColor="@color/white"
        android:textSize="@dimen/onboarding_btn_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnSkipNow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Secondary: "Skip for now" -->
    <TextView
        android:id="@+id/btnSkipNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="8dp"
        android:paddingHorizontal="20dp"
        android:text="@string/btn_skip_now"
        android:textColor="@color/text_body"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/dotIndicators"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dot indicators (3rd active) -->
    <LinearLayout
        android:id="@+id/dotIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Dot 1 — inactive -->
        <View
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 2 — inactive -->
        <View
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 3 — active (elongated pill) -->
        <View
            android:layout_width="@dimen/onboarding_dot_active_width"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_active" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
