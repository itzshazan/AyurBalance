<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/signupRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.auth.SignupActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <!-- ═══════════════════════════════════ -->
            <!--  LOGO + BRAND                       -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/brandRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/cd_app_logo"
                    android:src="@drawable/ic_leaf_triple" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="serif"
                    android:text="@string/app_name"
                    android:textColor="@color/primary_green"
                    android:textSize="26sp"
                    android:textStyle="bold|italic" />

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  HEADING                            -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:text="@string/create_account"
                android:textColor="@color/text_heading_dark"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/signup_subtitle"
                android:textColor="@color/text_caption"
                android:textSize="14sp" />

            <!-- ═══════════════════════════════════ -->
            <!--  FULL NAME FIELD                    -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.06"
                android:text="@string/label_full_name"
                android:textColor="@color/text_body"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="12dp"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_full_name"
                android:imeOptions="actionNext"
                android:importantForAutofill="yes"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_heading_dark"
                android:textColorHint="@color/text_subtext_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvNameError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/error_name_required"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- ═══════════════════════════════════ -->
            <!--  EMAIL FIELD                        -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.06"
                android:text="@string/label_email_address"
                android:textColor="@color/text_body"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="12dp"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_email"
                android:imeOptions="actionNext"
                android:importantForAutofill="yes"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_heading_dark"
                android:textColorHint="@color/text_subtext_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvEmailError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/error_email_invalid"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- ═══════════════════════════════════ -->
            <!--  PASSWORD FIELD                     -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.06"
                android:text="@string/label_password"
                android:textColor="@color/text_body"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/ic_lock_input"
                android:drawablePadding="12dp"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_password"
                android:imeOptions="actionNext"
                android:importantForAutofill="yes"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_heading_dark"
                android:textColorHint="@color/text_subtext_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPasswordError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/error_password_short"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- ═══════════════════════════════════ -->
            <!--  CONFIRM PASSWORD FIELD             -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvConfirmLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:letterSpacing="0.06"
                android:text="@string/label_confirm"
                android:textColor="@color/text_body"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/ic_check_shield"
                android:drawablePadding="12dp"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_password"
                android:imeOptions="actionDone"
                android:importantForAutofill="yes"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_heading_dark"
                android:textColorHint="@color/text_subtext_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvConfirmError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/error_password_mismatch"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- ═══════════════════════════════════ -->
            <!--  TERMS CHECKBOX                     -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/termsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="top"
                android:orientation="horizontal">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:buttonTint="@color/checkbox_tint"
                    android:minWidth="0dp"
                    android:minHeight="0dp" />

                <TextView
                    android:id="@+id/tvTermsText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/terms_agreement"
                    android:textColor="@color/text_body"
                    android:textSize="13sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvTermsError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="36dp"
                android:text="@string/error_terms_required"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- ═══════════════════════════════════ -->
            <!--  SIGN UP BUTTON + PROGRESS          -->
            <!-- ═══════════════════════════════════ -->

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <TextView
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:letterSpacing="0.02"
                    android:text="@string/btn_sign_up"
                    android:textColor="@color/white"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:elevation="5dp"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </FrameLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  ALREADY HAVE ACCOUNT               -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/bottomRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_have_account"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/login_text"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
