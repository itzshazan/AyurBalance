<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/privacyRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.onboarding.OnboardingPrivacyActivity">

    <!-- ═══════════════════════════════════════ -->
    <!--  TOP BAR: Brand + Dots                  -->
    <!-- ═══════════════════════════════════════ -->

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/dotsTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/tvAppName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvAppName">

        <!-- Dot 1 — inactive -->
        <View
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 2 — inactive -->
        <View
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 3 — inactive -->
        <View
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 4 — active (elongated pill) -->
        <View
            android:layout_width="@dimen/onboarding_dot_active_width"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_active" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════ -->
    <!--  HERO CARD                              -->
    <!-- ═══════════════════════════════════════ -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_privacy_hero"
            android:scaleType="centerCrop"
            android:src="@drawable/privacy_hero" />

    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════ -->
    <!--  BADGE CIRCLES (overlap hero bottom)    -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Lock badge (left) — green circle -->
    <FrameLayout
        android:id="@+id/badgeLock"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="50dp"
        android:background="@drawable/bg_badge_circle_green"
        android:elevation="10dp"
        android:translationY="-23dp"
        app:layout_constraintStart_toStartOf="@id/heroCard"
        app:layout_constraintTop_toBottomOf="@id/heroCard">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_lock_badge"
            android:src="@drawable/ic_lock_badge" />

    </FrameLayout>

    <!-- Shield badge (right) — orange circle -->
    <FrameLayout
        android:id="@+id/badgeShield"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginEnd="60dp"
        android:background="@drawable/bg_badge_circle_orange"
        android:elevation="10dp"
        android:translationY="-23dp"
        app:layout_constraintEnd_toEndOf="@id/heroCard"
        app:layout_constraintTop_toBottomOf="@id/heroCard">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_shield_badge"
            android:src="@drawable/ic_shield_badge" />

    </FrameLayout>

    <!-- ═══════════════════════════════════════ -->
    <!--  TEXT CONTENT                            -->
    <!-- ═══════════════════════════════════════ -->

    <!-- "Your Data is" -->
    <TextView
        android:id="@+id/tvHeading1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="serif"
        android:text="@string/privacy_heading_1"
        android:textColor="@color/text_heading_dark"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroCard" />

    <!-- "Sacred." (italic) -->
    <TextView
        android:id="@+id/tvHeading2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="serif"
        android:text="@string/privacy_heading_2"
        android:textColor="@color/text_heading_dark"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeading1" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="40dp"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/privacy_description"
        android:textColor="@color/text_caption"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeading2" />

    <!-- Trust highlights -->
    <TextView
        android:id="@+id/tvTrustHighlights"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:letterSpacing="0.04"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/trust_highlights"
        android:textColor="@color/text_status_brown"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDescription" />

    <!-- ═══════════════════════════════════════ -->
    <!--  BOTTOM SECTION                         -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Trust Badge Pill -->
    <LinearLayout
        android:id="@+id/trustBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_trust_badge_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/btnGetStarted"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Overlapping badge circles (small) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="28dp">

            <!-- Green shield circle (left) -->
            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_badge_circle_green">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_shield_badge"
                    android:src="@drawable/ic_shield_badge" />

            </FrameLayout>

            <!-- Orange lock circle (right, overlapping) -->
            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="end|center_vertical"
                android:background="@drawable/bg_badge_circle_orange">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_lock_badge"
                    android:src="@drawable/ic_lock_badge" />

            </FrameLayout>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:letterSpacing="0.06"
            android:text="@string/trusted_seekers"
            android:textColor="@color/text_body"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Primary CTA: "Get Started →" -->
    <TextView
        android:id="@+id/btnGetStarted"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_btn_primary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_get_started"
        android:textColor="@color/white"
        android:textSize="@dimen/onboarding_btn_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
