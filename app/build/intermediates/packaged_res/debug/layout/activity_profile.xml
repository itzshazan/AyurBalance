<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header ──────────────────────────────────────────── -->
            <FrameLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_green"
                android:paddingBottom="36dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="56dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:id="@+id/avatarCircle"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_avatar_circle">

                        <TextView
                            android:id="@+id/tvUserInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="A"
                            android:textColor="@color/primary_green"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvDisplayName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <!-- Prakriti type · Age -->
                    <TextView
                        android:id="@+id/tvProfileSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#B0FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                    <!-- Streak badge -->
                    <TextView
                        android:id="@+id/streakBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 0 day streak"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_streak_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                </LinearLayout>

            </FrameLayout>

            <!-- ── Content ─────────────────────────────────────────── -->

            <!-- Loading / empty / content groups -->
            <LinearLayout
                android:id="@+id/loadingGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <View android:layout_width="match_parent" android:layout_height="120dp"
                    android:layout_marginTop="8dp" android:background="@drawable/bg_analytics_card"
                    android:alpha="0.4"/>
                <View android:layout_width="match_parent" android:layout_height="120dp"
                    android:layout_marginTop="12dp" android:background="@drawable/bg_analytics_card"
                    android:alpha="0.4"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="48dp"
                android:paddingHorizontal="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete your Ayurvedic profile to personalize your wellness journey."
                    android:textColor="@color/text_caption"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/contentGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone">

                <!-- ── Prakriti Constitution Card ──────────────────── -->
                <LinearLayout
                    android:id="@+id/cardPrakriti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PRAKRITI CONSTITUTION"
                                android:textColor="@color/text_caption"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvConstitution"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/text_heading_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.4"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <!-- Vata bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="Vāta"
                            android:textColor="@color/vata_purple"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <FrameLayout
                            android:id="@+id/trackVata"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_macro_track">

                            <View
                                android:id="@+id/fillVata"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_dosha_bar_vata" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvVataPct"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/vata_purple"
                            android:textSize="12sp"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Pitta bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="Pitta"
                            android:textColor="@color/pitta_terracotta"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <FrameLayout
                            android:id="@+id/trackPitta"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_macro_track">

                            <View
                                android:id="@+id/fillPitta"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_dosha_bar_pitta" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvPittaPct"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/pitta_terracotta"
                            android:textSize="12sp"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Kapha bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="Kapha"
                            android:textColor="@color/primary_green"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <FrameLayout
                            android:id="@+id/trackKapha"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_macro_track">

                            <View
                                android:id="@+id/fillKapha"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_dosha_bar_kapha" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvKaphaPct"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/primary_green"
                            android:textSize="12sp"
                            android:gravity="end" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Wellness Profile Card ───────────────────────── -->
                <LinearLayout
                    android:id="@+id/cardDiet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="12dp"
                    android:elevation="2dp"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="WELLNESS PROFILE"
                            android:textColor="@color/text_caption"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.4"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <!-- Diet type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="88dp"
                            android:layout_height="wrap_content"
                            android:text="Diet"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvDietType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_body"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Goal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="88dp"
                            android:layout_height="wrap_content"
                            android:text="Goal"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_body"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Activity level -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="88dp"
                            android:layout_height="wrap_content"
                            android:text="Activity"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvActivityLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_body"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Health conditions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="88dp"
                            android:layout_height="wrap_content"
                            android:text="Notes"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvConditions"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/text_body"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Notifications Card ─────────────────────────── -->
                <LinearLayout
                    android:id="@+id/cardNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REMINDERS"
                        android:textColor="@color/text_caption"
                        android:textSize="10sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Meal reminders -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meal reminders"
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8:00 AM · 1:00 PM · 7:00 PM"
                                android:textColor="@color/text_caption"
                                android:textSize="11sp"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchMeals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider_light" />

                    <!-- Hydration reminders -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hydration reminders"
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Every 2 hours during the day"
                                android:textColor="@color/text_caption"
                                android:textSize="11sp"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchHydration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider_light" />

                    <!-- Dinacharya reminders -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dinacharya routine"
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Daily at 6:00 AM"
                                android:textColor="@color/text_caption"
                                android:textSize="11sp"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchDinacharya"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Action Rows ─────────────────────────────────── -->
                <View
                    android:id="@+id/dividerActions"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="@color/divider_light" />

                <!-- Privacy & Data -->
                <LinearLayout
                    android:id="@+id/rowPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Privacy &amp; Data"
                        android:textColor="@color/text_body"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:alpha="0.35"
                        android:contentDescription="@null" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light" />

                <!-- Export PDF -->
                <TextView
                    android:id="@+id/btnExportPdf"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp"
                    android:text="Export Health Report (PDF)"
                    android:textColor="@color/text_body"
                    android:textSize="14sp"
                    android:foreground="?attr/selectableItemBackground" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light" />

                <!-- Retake Assessment -->
                <LinearLayout
                    android:id="@+id/rowRetakeAssessment"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Retake Prakriti Assessment"
                        android:textColor="@color/text_body"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:alpha="0.35"
                        android:contentDescription="@null" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light" />

                <!-- Sign Out -->
                <TextView
                    android:id="@+id/rowSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp"
                    android:text="Sign Out"
                    android:textColor="#C4572A"
                    android:textSize="14sp"
                    android:foreground="?attr/selectableItemBackground" />

                <!-- Version -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AyurBalance · Version 1.0"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom Navigation ──────────────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_home"
        app:labelVisibilityMode="labeled"
        app:itemTextColor="@color/text_caption" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
