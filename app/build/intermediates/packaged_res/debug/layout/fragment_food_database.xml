<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etFoodSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_input_field"
        android:hint="Search food item or ingredient…"
        android:inputType="text"
        android:paddingHorizontal="14dp"
        android:textColor="@color/text_heading_dark"
        android:textColorHint="@color/text_caption"
        android:textSize="13sp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">

        <TextView android:id="@+id/chipFoodAll" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary" android:clickable="true" android:focusable="true"
            android:layout_marginEnd="6dp" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:text="All" android:textColor="@color/white" android:textSize="12sp" />

        <TextView android:id="@+id/chipFoodIcmr" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_activity_card" android:clickable="true" android:focusable="true"
            android:layout_marginEnd="6dp" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:text="ICMR" android:textColor="@color/text_body" android:textSize="12sp" />

        <TextView android:id="@+id/chipFoodUsda" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_activity_card" android:clickable="true" android:focusable="true"
            android:layout_marginEnd="6dp" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:text="USDA" android:textColor="@color/text_body" android:textSize="12sp" />

        <TextView android:id="@+id/chipFoodFlagged" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_activity_card" android:clickable="true" android:focusable="true"
            android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:text="Flagged" android:textColor="@color/text_body" android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_admin_card"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFoodItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</LinearLayout>
