<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/locationRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.location.LocationPermissionActivity">

    <!-- ═══════════════════════════════════ -->
    <!--  TOP BAR                            -->
    <!-- ═══════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:contentDescription="@string/cd_back_button"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <!-- ═══════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                 -->
    <!-- ═══════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ═══════════════════════════════════ -->
            <!--  STATE 1: PERMISSION REQUEST        -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/layoutPermissionRequest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="16dp"
                android:paddingBottom="40dp"
                android:gravity="center_horizontal"
                android:visibility="visible">

                <!-- Illustration -->
                <ImageView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_location_leaf" />

                <!-- Heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="@string/location_heading"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.15" />

                <!-- Body copy -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/location_body"
                    android:textColor="@color/text_caption"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5" />

                <!-- Info card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_info_card"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_leaf_small_green"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/location_privacy_note"
                        android:textColor="@color/text_body"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:fontFamily="sans-serif-light"
                        android:textStyle="italic" />

                </LinearLayout>

                <!-- Allow Location Button -->
                <TextView
                    android:id="@+id/btnAllowLocation"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/btn_allow_location"
                    android:textColor="@color/white"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold" />

                <!-- Skip ghost link -->
                <TextView
                    android:id="@+id/btnSkipLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/btn_skip_location"
                    android:textColor="@color/primary_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  STATE 2: MANUAL FALLBACK           -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/layoutManualFallback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="40dp"
                android:visibility="gone">

                <!-- Heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="@string/manual_region_heading"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Sub text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/manual_region_body"
                    android:textColor="@color/text_caption"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4" />

                <!-- Region Spinner container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_activity_card"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="8dp"
                        android:letterSpacing="0.1"
                        android:text="@string/label_your_region"
                        android:textColor="@color/step_indicator_red"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/regionDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="12dp" />

                </LinearLayout>

                <!-- Climate zone preview card -->
                <LinearLayout
                    android:id="@+id/climatePreviewCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_info_card_peach"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/dot_amber_small" />

                    <TextView
                        android:id="@+id/tvClimateZonePreview"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_body"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Confirm Region Button -->
                <TextView
                    android:id="@+id/btnConfirmRegion"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/onboarding_btn_height"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:elevation="3dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/btn_confirm_region"
                    android:textColor="@color/white"
                    android:textSize="@dimen/onboarding_btn_text_size"
                    android:textStyle="bold" />

                <!-- Footer note -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/location_footer_note"
                    android:textColor="@color/text_subtext_grey"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </FrameLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
