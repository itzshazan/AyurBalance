<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resultRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream"
    android:orientation="vertical">

    <!-- ═══════════════════════════════════ -->
    <!--  HEADER                             -->
    <!-- ═══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.4"
        android:background="@drawable/bg_result_header"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:alpha="0">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="start"
            android:layout_marginStart="14dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_result_icon_circle"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_arrow"
            android:tint="@color/white"
            android:scaleType="center" />

        <!-- Dosha emoji -->
        <LinearLayout
            android:id="@+id/iconCircle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_result_icon_circle"
            android:gravity="center"
            android:scaleX="0.5"
            android:scaleY="0.5"
            android:alpha="0">

            <TextView
                android:id="@+id/tvDoshaEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="30sp" />

        </LinearLayout>

        <!-- Dosha type -->
        <TextView
            android:id="@+id/tvDoshaType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="serif"
            android:text="—"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Elements -->
        <TextView
            android:id="@+id/tvDoshaDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"
            android:text="—"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════ -->
    <!--  BODY                               -->
    <!-- ═══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5.6"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- 3 Dosha cards side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.6"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Vata -->
            <LinearLayout
                android:id="@+id/cardVata"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_dosha_card_vata"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="10dp"
                android:alpha="0"
                android:translationY="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌬️"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vata"
                    android:textColor="#5533AA"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVataPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#5533AA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <FrameLayout
                    android:id="@+id/trackVata"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/progress_track">
                    <View
                        android:id="@+id/fillVata"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_dosha_bar_vata" />
                </FrameLayout>

            </LinearLayout>

            <!-- Pitta -->
            <LinearLayout
                android:id="@+id/cardPitta"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_dosha_card_pitta"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="10dp"
                android:alpha="0"
                android:translationY="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pitta"
                    android:textColor="#A04020"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPittaPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#A04020"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <FrameLayout
                    android:id="@+id/trackPitta"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/progress_track">
                    <View
                        android:id="@+id/fillPitta"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_dosha_bar_pitta" />
                </FrameLayout>

            </LinearLayout>

            <!-- Kapha -->
            <LinearLayout
                android:id="@+id/cardKapha"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_dosha_card_kapha"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="10dp"
                android:alpha="0"
                android:translationY="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kapha"
                    android:textColor="#2D5F1B"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvKaphaPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#2D5F1B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <FrameLayout
                    android:id="@+id/trackKapha"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/progress_track">
                    <View
                        android:id="@+id/fillKapha"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_dosha_bar_kapha" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Insights card — single card with 4 rows -->
        <LinearLayout
            android:id="@+id/blockPhysical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:background="@drawable/bg_activity_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What this means"
                android:textColor="@color/text_heading_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="10dp" />

            <!-- Physical -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="💪 Physical" android:textColor="@color/text_caption"
                    android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvPhysicalInsight" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="—" android:textColor="@color/text_body"
                    android:textSize="11sp" android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_light" android:layout_marginVertical="6dp" />

            <!-- Mental -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="🧠 Mental" android:textColor="@color/text_caption"
                    android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvMentalInsight" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="—" android:textColor="@color/text_body"
                    android:textSize="11sp" android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_light" android:layout_marginVertical="6dp" />

            <!-- Risks -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="⚠️ Risks" android:textColor="@color/text_caption"
                    android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvRisksInsight" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="—" android:textColor="@color/text_body"
                    android:textSize="11sp" android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_light" android:layout_marginVertical="6dp" />

            <!-- Recommendations -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="🌱 For you" android:textColor="@color/primary_green_dark"
                    android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvRecsInsight" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="—" android:textColor="@color/text_body"
                    android:textSize="11sp" android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

        </LinearLayout>

        <!-- CTA Button -->
        <TextView
            android:id="@+id/btnBeginJourney"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:elevation="2dp"
            android:focusable="true"
            android:gravity="center"
            android:text="Begin my journey  →"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:alpha="0" />

    </LinearLayout>

</LinearLayout>
