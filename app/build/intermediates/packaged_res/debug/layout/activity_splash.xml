<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background"
    tools:context=".ui.splash.SplashActivity">

    <!-- ═══════════════════════════════════════ -->
    <!--  TOP-LEFT PLANT IMAGE OVERLAY          -->
    <!-- ═══════════════════════════════════════ -->
    <ImageView
        android:id="@+id/imgPlantOverlay"
        android:layout_width="@dimen/splash_plant_size"
        android:layout_height="@dimen/splash_plant_size"
        android:layout_marginStart="@dimen/splash_plant_margin_start"
        android:layout_marginTop="@dimen/splash_plant_margin_top"
        android:alpha="0.88"
        android:contentDescription="@string/cd_plant_decoration"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_plant_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ═══════════════════════════════════════ -->
    <!--  CENTER BRANDING — BADGE + TEXT         -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Circular badge with leaf icon -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/badgeContainer"
        android:layout_width="@dimen/splash_badge_size"
        android:layout_height="@dimen/splash_badge_size"
        android:alpha="0"
        android:scaleX="0.8"
        android:scaleY="0.8"
        app:cardBackgroundColor="@color/badge_circle_bg"
        app:cardCornerRadius="@dimen/splash_badge_radius"
        app:cardElevation="@dimen/splash_badge_elevation"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_app_logo"
            android:padding="@dimen/splash_badge_padding"
            android:src="@drawable/ic_leaf_triple" />

    </com.google.android.material.card.MaterialCardView>

    <!-- App Name: "AyurBalance" -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:alpha="0"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/text_dark_green"
        android:textSize="@dimen/splash_app_name_size"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/badgeContainer" />

    <!-- Tagline: "ANCIENT WISDOM, MODERN BALANCE" -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:alpha="0"
        android:gravity="center"
        android:letterSpacing="0.16"
        android:paddingStart="56dp"
        android:paddingEnd="56dp"
        android:text="@string/tagline"
        android:textColor="@color/text_tagline_brown"
        android:textSize="@dimen/splash_tagline_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- ═══════════════════════════════════════ -->
    <!--  BOTTOM SECTION                         -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Guideline to mark bottom section start -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70" />

    <!-- Bottom section background -->
    <View
        android:id="@+id/bottomSectionBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/splash_bottom_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guidelineBottom" />

    <!-- Faded botanical illustration — overlaps boundary between main & bottom sections -->
    <ImageView
        android:id="@+id/imgBotanicalBottom"
        android:layout_width="@dimen/splash_botanical_width"
        android:layout_height="@dimen/splash_botanical_height"
        android:layout_marginBottom="16dp"
        android:alpha="0.28"
        android:contentDescription="@string/cd_botanical_decoration"
        android:scaleType="fitCenter"
        android:src="@drawable/splash_botanical_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ═══════════════════════════════════════ -->
    <!--  LOADING SECTION                        -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Progress bar track -->
    <View
        android:id="@+id/progressTrack"
        android:layout_width="@dimen/splash_progress_width"
        android:layout_height="@dimen/splash_progress_height"
        android:layout_marginBottom="14dp"
        android:alpha="0"
        android:background="@color/progress_track"
        android:contentDescription="@string/cd_progress_bar"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Progress bar fill (scaleX animated from 0 → 1, pivoting from left edge) -->
    <View
        android:id="@+id/progressFill"
        android:layout_width="@dimen/splash_progress_width"
        android:layout_height="@dimen/splash_progress_height"
        android:background="@color/progress_fill"
        android:scaleX="0"
        android:transformPivotX="0dp"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="@id/progressTrack"
        app:layout_constraintTop_toTopOf="@id/progressTrack" />

    <!-- Status text: "INITIALIZING AI DOSHA ENGINE" -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:alpha="0"
        android:letterSpacing="0.05"
        android:text="@string/status_initializing"
        android:textColor="@color/text_status_brown"
        android:textSize="@dimen/splash_status_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvSubtext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Subtext: "Verifying Prakriti alignment…" -->
    <TextView
        android:id="@+id/tvSubtext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:alpha="0"
        android:text="@string/status_verifying"
        android:textColor="@color/text_subtext_grey"
        android:textSize="@dimen/splash_subtext_size"
        app:layout_constraintBottom_toTopOf="@id/iconTreeBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Small tree icon at bottom -->
    <ImageView
        android:id="@+id/iconTreeBottom"
        android:layout_width="@dimen/splash_tree_icon_size"
        android:layout_height="@dimen/splash_tree_icon_size"
        android:layout_marginBottom="20dp"
        android:alpha="0"
        android:contentDescription="@string/cd_tree_icon"
        android:src="@drawable/ic_tree_small"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
