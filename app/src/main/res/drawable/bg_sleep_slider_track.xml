<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background" android:gravity="center_vertical">
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <solid android:color="#EAE4DA" />
            <size android:height="6dp"/>
        </shape>
    </item>
    <item android:id="@android:id/progress" android:gravity="center_vertical">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp"/>
                <!-- We keep it same as bg to hide "progress" green filling -->
                <solid android:color="#EAE4DA" />
            </shape>
        </clip>
    </item>
</layer-list>
