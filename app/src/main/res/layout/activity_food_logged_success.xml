<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/successRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_cream">

    <!-- ══════════════════════════════════ -->
    <!--  SUCCESS HEADER (dark green)       -->
    <!-- ══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/successHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_success_header"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="56dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp">

        <!-- Check circle -->
        <FrameLayout
            android:id="@+id/checkCircle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_check_circle"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✓"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Food logged label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Food Logged!"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="6dp" />

        <!-- Food name -->
        <TextView
            android:id="@+id/tvSuccessFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dal Makhani"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <!-- Meal type + time -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMealType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunch"
                android:textColor="#99FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ·  "
                android:textColor="#66FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvLogTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:34 PM"
                android:textColor="#99FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════ -->
    <!--  SCROLLABLE BODY                   -->
    <!-- ══════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nutrition Summary label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nutrition Summary"
                android:textColor="@color/text_heading_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 2×2 Nutrition Card Grid -->
            <LinearLayout
                android:id="@+id/nutritionGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- Calories card -->
                    <LinearLayout
                        android:id="@+id/cardCalories"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_nutrition_card"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥"
                            android:textSize="20sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KCAL"
                            android:textColor="@color/text_caption"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06" />

                    </LinearLayout>

                    <!-- Protein card -->
                    <LinearLayout
                        android:id="@+id/cardProtein"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_nutrition_card"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪"
                            android:textSize="20sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PROTEIN (G)"
                            android:textColor="@color/text_caption"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Carbs card -->
                    <LinearLayout
                        android:id="@+id/cardCarbs"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_nutrition_card"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌾"
                            android:textSize="20sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CARBS (G)"
                            android:textColor="@color/text_caption"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06" />

                    </LinearLayout>

                    <!-- Fat card -->
                    <LinearLayout
                        android:id="@+id/cardFat"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_nutrition_card"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🫒"
                            android:textSize="20sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FAT (G)"
                            android:textColor="@color/text_caption"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════ -->
            <!--  AYURVEDIC PROPERTIES              -->
            <!-- ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/ayurvedicSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ayurvedic_section"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ayurvedic Properties"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Chips row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/chipRasa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_ayurvedic_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Rasa: —"
                        android:textColor="@color/text_body"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chipGuna"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_ayurvedic_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Guna: —"
                        android:textColor="@color/text_body"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Dosha effect chip -->
                <TextView
                    android:id="@+id/chipDoshaEffect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ayurvedic_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Dosha: —"
                    android:textColor="@color/pitta_terracotta"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"
                    android:layout_marginBottom="12dp" />

                <!-- Insight text -->
                <TextView
                    android:id="@+id/tvAyurvedicInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eat mindfully and chew thoroughly."
                    android:textColor="@color/text_body"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- ══════════════════════════════════ -->
            <!--  DAILY CALORIE PROGRESS            -->
            <!-- ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/dailyProgressCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_daily_progress_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Circular progress -->
                <com.ayurbalance.ui.dashboard.CircularProgressView
                    android:id="@+id/dailyProgressCircle"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="16dp" />

                <!-- Labels -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Calories"
                        android:textColor="@color/text_caption"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvDailyConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— kcal consumed"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvDailyGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="of 2000 kcal goal"
                        android:textColor="@color/text_caption"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════ -->
            <!--  VIEW JOURNAL CTA                  -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:id="@+id/btnViewJournal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="View Journal  →"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Back to dashboard link -->
            <TextView
                android:id="@+id/tvBackToDashboard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Back to Dashboard"
                android:textColor="@color/text_caption"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════ -->
    <!--  BOTTOM NAVIGATION                 -->
    <!-- ══════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_cream"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_home"
        app:elevation="8dp" />

</LinearLayout>
