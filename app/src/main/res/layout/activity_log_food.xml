<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/logFoodRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111A14">

    <!-- ══════════════════════════════════ -->
    <!--  CAMERA VIEWFINDER                 -->
    <!-- ══════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Simulated camera background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1E2B1A" />

        <!-- Viewfinder overlay (brackets + focus ring) -->
        <com.ayurbalance.ui.logfood.ViewfinderView
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Prompt text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.12"
            android:text="POINT CAMERA AT FOOD"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Scanning shimmer (visible during scan phase) -->
        <LinearLayout
            android:id="@+id/scanningOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identifying..."
                android:textColor="#CCFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

    <!-- ══════════════════════════════════ -->
    <!--  RESULTS SHEET                     -->
    <!-- ══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_cream"
        android:orientation="vertical">

        <!-- Tab row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_cream"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_food_tab_group"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabCamera"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_food_tab_selected"
                    android:gravity="center"
                    android:text="CAMERA"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tabSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="SEARCH"
                    android:textColor="@color/text_body"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tabBarcode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="BARCODE"
                    android:textColor="@color/text_body"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tabVoice"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="VOICE"
                    android:textColor="@color/text_body"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

            </LinearLayout>

        </LinearLayout>

        <!-- Results content (hidden while scanning) -->
        <LinearLayout
            android:id="@+id/resultsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <!-- Header: "Identified: Dal Makhani" + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvIdentifiedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Identified: "
                    android:textColor="@color/text_heading_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tvIdentifiedName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dal Makhani"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvConfidenceBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_confidence_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="87% CONFIDENT"
                    android:textColor="@color/primary_green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

            </LinearLayout>

            <!-- Result row 0 (selected) -->
            <LinearLayout
                android:id="@+id/row0"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_food_result_selected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvName0"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dal Makhani"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvConf0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="87%"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Result row 1 -->
            <LinearLayout
                android:id="@+id/row1"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_food_result_unselected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvName1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rajma curry"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvConf1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9%"
                    android:textColor="@color/text_caption"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Result row 2 -->
            <LinearLayout
                android:id="@+id/row2"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_food_result_unselected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvName2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kali dal"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvConf2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4%"
                    android:textColor="@color/text_caption"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Dosha + Calorie tags -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvDoshaTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_tag_pitta"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🔥  PITTA HEAVY"
                    android:textColor="@color/pitta_terracotta"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvCalorieTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_neutral"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🌡  420 KCAL / 100G"
                    android:textColor="@color/text_body"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

            </LinearLayout>

            <!-- Confirm & log button -->
            <TextView
                android:id="@+id/btnConfirmLog"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="Confirm &amp; log  →"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════ -->
    <!--  BOTTOM NAVIGATION                 -->
    <!-- ══════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_cream"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_home"
        app:elevation="8dp" />

</LinearLayout>
