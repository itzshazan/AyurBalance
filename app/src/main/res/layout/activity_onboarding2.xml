<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/onboarding2Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.onboarding.Onboarding2Activity">

    <!-- ═══════════════════════════════════════ -->
    <!--  DECORATIVE LEAF WATERMARK              -->
    <!-- ═══════════════════════════════════════ -->

    <ImageView
        android:id="@+id/leafDecoration"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginEnd="-16dp"
        android:alpha="0.07"
        android:contentDescription="@null"
        android:src="@drawable/ic_leaf_triple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.40" />

    <!-- ═══════════════════════════════════════ -->
    <!--  PHONE MOCKUP                           -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Outer phone frame (beige bezel) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/phoneFrame"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/phone_frame_bg"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <!-- Inner screen (dark) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/phoneScreen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="true"
                    android:clipToPadding="true">

                    <!-- ─── FOOD IMAGE ─── -->
                    <ImageView
                        android:id="@+id/foodImage"
                        android:layout_width="0dp"
                        android:layout_height="320dp"
                        android:contentDescription="@string/cd_food_analysis"
                        android:scaleType="centerCrop"
                        android:src="@drawable/onboarding_food_bowl"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- ─── GRID OVERLAY LINES ─── -->

                    <!-- Horizontal grid line at 33% -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0.5dp"
                        android:background="@color/grid_line"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintEnd_toEndOf="@id/foodImage"
                        app:layout_constraintStart_toStartOf="@id/foodImage"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintVertical_bias="0.333" />

                    <!-- Horizontal grid line at 66% -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0.5dp"
                        android:background="@color/grid_line"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintEnd_toEndOf="@id/foodImage"
                        app:layout_constraintStart_toStartOf="@id/foodImage"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintVertical_bias="0.666" />

                    <!-- Vertical grid line at 33% -->
                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="0dp"
                        android:background="@color/grid_line"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintHorizontal_bias="0.333" />

                    <!-- Vertical grid line at 66% -->
                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="0dp"
                        android:background="@color/grid_line"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintHorizontal_bias="0.666" />

                    <!-- ─── AI DETECTION LABELS ─── -->

                    <!-- AVOCADO (PITTA ↓) label -->
                    <LinearLayout
                        android:id="@+id/labelAvocado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_ai_label"
                        android:elevation="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintVertical_bias="0.22">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_green_small" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/ai_label_avocado"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- QUINOA (TRIDOSHIC) label -->
                    <LinearLayout
                        android:id="@+id/labelQuinoa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:background="@drawable/bg_ai_label"
                        android:elevation="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/foodImage"
                        app:layout_constraintVertical_bias="0.62">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_amber_small" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/ai_label_quinoa"
                            android:textColor="@color/text_heading_dark"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- ─── ANALYSIS RESULTS CARD ─── -->

                    <LinearLayout
                        android:id="@+id/analysisCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_analysis_card"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        app:layout_constraintBottom_toBottomOf="@id/foodImage"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <!-- Title row: Vitality Bowl + Check icon -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvVitalityBowl"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="@string/vitality_bowl"
                                android:textColor="@color/text_heading_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/icCheck"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/icCheck"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@string/cd_check_icon"
                                android:src="@drawable/ic_check_circle"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Dosha indicators row -->
                        <LinearLayout
                            android:id="@+id/doshaRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <!-- VATA 60% -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_dosha_default"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.08"
                                    android:text="@string/dosha_vata_label"
                                    android:textColor="@color/text_tagline_brown"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dosha_vata_value"
                                    android:textColor="@color/text_heading_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- PITTA 85% (highlighted) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="2dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_dosha_highlight"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.08"
                                    android:text="@string/dosha_pitta_label"
                                    android:textColor="@color/text_tagline_brown"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dosha_pitta_value"
                                    android:textColor="@color/text_heading_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- KAPHA 40% -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_dosha_default"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.08"
                                    android:text="@string/dosha_kapha_label"
                                    android:textColor="@color/text_tagline_brown"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dosha_kapha_value"
                                    android:textColor="@color/text_heading_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════ -->
    <!--  CONTENT BELOW PHONE MOCKUP             -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Page indicator dots (2nd active) -->
    <LinearLayout
        android:id="@+id/dotIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/phoneFrame">

        <!-- Dot 1 — inactive -->
        <View
            android:id="@+id/dot1"
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:background="@drawable/bg_dot_inactive" />

        <!-- Dot 2 — active (elongated pill) -->
        <View
            android:id="@+id/dot2"
            android:layout_width="@dimen/onboarding_dot_active_width"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_active" />

        <!-- Dot 3 — inactive -->
        <View
            android:id="@+id/dot3"
            android:layout_width="@dimen/onboarding_dot_height"
            android:layout_height="@dimen/onboarding_dot_height"
            android:layout_marginStart="@dimen/onboarding_dot_spacing"
            android:background="@drawable/bg_dot_inactive" />

    </LinearLayout>

    <!-- "VISION INTELLIGENCE" pill tag -->
    <TextView
        android:id="@+id/tvVisionTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_vision_pill"
        android:letterSpacing="0.12"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="@string/vision_intelligence"
        android:textColor="@color/primary_green"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dotIndicators" />

    <!-- Heading 1: "Smart Food" — serif bold, dark -->
    <TextView
        android:id="@+id/tvHeadingLine1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="10dp"
        android:fontFamily="serif"
        android:text="@string/onboarding2_heading_1"
        android:textColor="@color/text_heading_dark"
        android:textSize="@dimen/onboarding_heading_size"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVisionTag" />

    <!-- Heading 2: "Logging." — serif bold italic, green -->
    <TextView
        android:id="@+id/tvHeadingLine2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginTop="2dp"
        android:fontFamily="serif"
        android:text="@string/onboarding2_heading_2"
        android:textColor="@color/text_dark_green"
        android:textSize="@dimen/onboarding_heading_size"
        android:textStyle="bold|italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeadingLine1" />

    <!-- ═══════════════════════════════════════ -->
    <!--  ACTION BUTTONS (reused from Screen 1)  -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Primary: "Next →" -->
    <TextView
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_btn_primary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_next"
        android:textColor="@color/white"
        android:textSize="@dimen/onboarding_btn_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnSkip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Secondary: "Skip" -->
    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="0dp"
        android:layout_height="@dimen/onboarding_btn_height"
        android:layout_marginStart="@dimen/onboarding_margin"
        android:layout_marginEnd="@dimen/onboarding_margin"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_btn_secondary"
        android:clickable="true"
        android:elevation="3dp"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:text="@string/btn_skip"
        android:textColor="@color/text_body"
        android:textSize="@dimen/onboarding_btn_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
