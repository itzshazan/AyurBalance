<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/otpRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.auth.OtpVerificationActivity">

    <!-- ═══════════════════════════════════ -->
    <!--  TOP BAR: Back + Brand             -->
    <!-- ═══════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:contentDescription="@string/cd_back_button"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <!-- ═══════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                -->
    <!-- ═══════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- ═══════════════════════════════════ -->
            <!--  MAIN CARD CONTAINER                -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/otpCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- Email icon circle -->
                <FrameLayout
                    android:id="@+id/iconCircle"
                    android:layout_width="52dp"
                    android:layout_height="52dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_otp_icon_circle" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_otp_email_icon"
                        android:src="@drawable/ic_email_green" />

                </FrameLayout>

                <!-- Heading -->
                <TextView
                    android:id="@+id/tvHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:lineSpacingMultiplier="1.1"
                    android:text="@string/otp_heading"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingMultiplier="1.4"
                    android:text="@string/otp_description"
                    android:textColor="@color/text_caption"
                    android:textSize="14sp" />

                <!-- ═══════════════════════════════ -->
                <!--  OTP INPUT BOXES (8 digits)     -->
                <!-- ═══════════════════════════════ -->

                <LinearLayout
                    android:id="@+id/otpRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etOtp1"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp" />

                    <EditText
                        android:id="@+id/etOtp2"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp3"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp4"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp5"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp6"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp7"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp" />

                    <EditText
                        android:id="@+id/etOtp8"
                        style="@style/OtpBoxStyle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- ═══════════════════════════════ -->
                <!--  VERIFY BUTTON + PROGRESS       -->
                <!-- ═══════════════════════════════ -->

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:id="@+id/btnVerify"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/onboarding_btn_height"
                        android:background="@drawable/bg_btn_primary"
                        android:clickable="true"
                        android:elevation="3dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:letterSpacing="0.02"
                        android:text="@string/btn_verify_code"
                        android:textColor="@color/white"
                        android:textSize="@dimen/onboarding_btn_text_size"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:elevation="5dp"
                        android:indeterminateTint="@color/white"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </FrameLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  RESEND TIMER                       -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/timerRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_clock" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/text_body"
                    android:textSize="13sp"
                    tools:text="Resend code in 02:59" />

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  DIDN'T RECEIVE EMAIL?              -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.04"
                android:text="@string/didnt_receive_email"
                android:textColor="@color/text_status_brown"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Spacer fills remaining space -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ═══════════════════════════════════ -->
            <!--  FOOTER                             -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.08"
                android:text="@string/otp_footer"
                android:textColor="@color/text_subtext_grey"
                android:textSize="9sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
