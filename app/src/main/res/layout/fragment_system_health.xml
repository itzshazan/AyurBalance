<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Metric cards row 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/bg_admin_metric_card"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30-day uptime" android:textColor="@color/text_caption" android:textSize="11sp" />
                <TextView android:id="@+id/tvUptime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_heading_dark" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/bg_admin_metric_card"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avg API latency" android:textColor="@color/text_caption" android:textSize="11sp" />
                <TextView android:id="@+id/tvAvgLatency" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_heading_dark" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Metric cards row 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/bg_admin_metric_card"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Error rate (24h)" android:textColor="@color/text_caption" android:textSize="11sp" />
                <TextView android:id="@+id/tvErrorRate" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_heading_dark" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/bg_admin_metric_card"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DB connections" android:textColor="@color/text_caption" android:textSize="11sp" />
                <TextView android:id="@+id/tvDbConnections" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_heading_dark" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Service status card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_card" android:orientation="vertical"
            android:padding="14dp" android:layout_marginBottom="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Service status" android:textColor="@color/text_heading_dark"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <!-- Background jobs card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_card" android:orientation="vertical"
            android:padding="14dp" android:layout_marginBottom="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Background jobs" android:textColor="@color/text_heading_dark"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

            <!-- Job: DB backup -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily DB backup" android:textColor="@color/text_heading_dark"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last run: today 02:00 · Next: tomorrow 02:00"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@color/pill_green_bg" android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                    android:text="OK" android:textColor="@color/pill_green_text"
                    android:textSize="11sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Job: ML retraining -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ML retraining pipeline" android:textColor="@color/text_heading_dark"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last run: 3 days ago · Weekly cadence"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@color/pill_green_bg" android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                    android:text="OK" android:textColor="@color/pill_green_text"
                    android:textSize="11sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Job: Seasonal push -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Seasonal push notifications" android:textColor="@color/text_heading_dark"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last run: today 07:00 · Daily at 07:00"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@color/pill_green_bg" android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                    android:text="OK" android:textColor="@color/pill_green_text"
                    android:textSize="11sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Job: GDPR cleanup -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GDPR deletion cleanup" android:textColor="@color/text_heading_dark"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last run: yesterday · Runs at midnight"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@color/pill_amber_bg" android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                    android:text="Slow" android:textColor="@color/pill_amber_text"
                    android:textSize="11sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Recent errors card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_card" android:orientation="vertical"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Recent errors (24h)" android:textColor="@color/text_heading_dark"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

            <!-- Error 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="8dp">
                <TextView android:layout_width="58dp" android:layout_height="wrap_content"
                    android:text="09:14" android:textColor="@color/text_caption" android:textSize="11sp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ML inference timeout" android:textColor="@color/error_red"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="user_id: a3f2 · prakriti_clf_v2.4 · 5021 ms"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Error 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="8dp">
                <TextView android:layout_width="58dp" android:layout_height="wrap_content"
                    android:text="11:02" android:textColor="@color/text_caption" android:textSize="11sp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Realtime connection drop" android:textColor="@color/error_red"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Realtime channel: live_activity · recovered in 3s"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Error 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="8dp">
                <TextView android:layout_width="58dp" android:layout_height="wrap_content"
                    android:text="14:37" android:textColor="@color/text_caption" android:textSize="11sp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Storage upload 413" android:textColor="@color/pill_amber_text"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="food_images bucket · file too large · 8.4 MB"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EDE6" />

            <!-- Error 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="8dp">
                <TextView android:layout_width="58dp" android:layout_height="wrap_content"
                    android:text="18:50" android:textColor="@color/text_caption" android:textSize="11sp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Auth token refresh failed" android:textColor="@color/error_red"
                        android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 users affected · auto-logout triggered"
                        android:textColor="@color/text_caption" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
