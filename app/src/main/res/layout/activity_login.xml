<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bottom_bg"
    tools:context=".ui.auth.LoginActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- ═══════════════════════════════════ -->
            <!--  BRAND                              -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:id="@+id/tvBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/app_name"
                android:textColor="@color/primary_green"
                android:textSize="22sp"
                android:textStyle="bold|italic" />

            <!-- ═══════════════════════════════════ -->
            <!--  HEADING: Welcome Back              -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/headingRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="@string/welcome_text"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="@string/back_text"
                    android:textColor="@color/primary_green"
                    android:textSize="34sp"
                    android:textStyle="bold|italic" />

            </LinearLayout>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/login_subtitle"
                android:textColor="@color/text_caption"
                android:textSize="15sp" />

            <!-- ═══════════════════════════════════ -->
            <!--  LOGIN CARD                         -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- EMAIL ADDRESS -->
                <TextView
                    android:id="@+id/tvEmailLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="@string/label_email_address"
                    android:textColor="@color/text_body"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="12dp"
                    android:fontFamily="sans-serif"
                    android:hint="@string/hint_email_full"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_heading_dark"
                    android:textColorHint="@color/text_subtext_grey"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvEmailError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/error_email_invalid"
                    android:textColor="@color/error_red"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- PASSWORD ROW: Label + Forgot Password? -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPasswordLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.06"
                        android:text="@string/label_password"
                        android:textColor="@color/text_body"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/forgot_password"
                        android:textColor="@color/text_status_brown"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Password input with eye toggle -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_lock_input"
                        android:drawablePadding="12dp"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_password"
                        android:imeOptions="actionDone"
                        android:importantForAutofill="yes"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="@color/text_heading_dark"
                        android:textColorHint="@color/text_subtext_grey"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivTogglePassword"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@string/cd_toggle_password"
                        android:padding="8dp"
                        android:src="@drawable/ic_eye" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvPasswordError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/error_invalid_credentials"
                    android:textColor="@color/error_red"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- LOGIN BUTTON + PROGRESS -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp">

                    <TextView
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/onboarding_btn_height"
                        android:background="@drawable/bg_btn_primary"
                        android:clickable="true"
                        android:elevation="3dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:letterSpacing="0.02"
                        android:text="@string/btn_login"
                        android:textColor="@color/white"
                        android:textSize="@dimen/onboarding_btn_text_size"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:elevation="5dp"
                        android:indeterminateTint="@color/white"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </FrameLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  OR CONTINUE WITH DIVIDER           -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/dividerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:letterSpacing="0.06"
                    android:text="@string/or_continue_with"
                    android:textColor="@color/text_subtext_grey"
                    android:textSize="10sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_light" />

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  SOCIAL BUTTONS                     -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/socialRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Google Button -->
                <LinearLayout
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_social_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/cd_google_icon"
                        android:src="@drawable/ic_google" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/google_text"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Microsoft Button -->
                <LinearLayout
                    android:id="@+id/btnMicrosoft"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_social_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@string/cd_microsoft_icon"
                        android:src="@drawable/ic_microsoft" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/microsoft_text"
                        android:textColor="@color/text_heading_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--  NEW TO AYURBALANCE?                -->
            <!-- ═══════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/bottomRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_to_balance"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCreateAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/create_account_text"
                    android:textColor="@color/text_heading_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
